{
  "name": "bpmn-workbench",
  "version": "0.1.0",
  "type": "module",
  "description": "An educational BPMN modelling + simulation workbench, and the home of the essential model-checking rules and the issues panel",
  "main": "src/app.js",
  "exports": {
    "./rules": "./src/modules/rules/index.js",
    "./rules/*": "./src/modules/rules/*",
    "./issues": "./src/modules/issues/index.js",
    "./issues/*": "./src/modules/issues/*",
    "./toolbar": "./src/modules/toolbar/index.js",
    "./toolbar/*": "./src/modules/toolbar/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test test/*.test.mjs"
  },
  "author": {
    "name": "Asvin Goel"
  },
  "contributors": [
    {
      "name": "bpmn.io contributors",
      "url": "https://github.com/bpmn-io"
    }
  ],
  "license": "MIT",
  "dependencies": {
    "bpmn-js": "^18.19.0",
    "bpmn-js-animation": "github:bpmn-os/bpmn-js-animation#3a73f2c31054028a0aa9a778e6e72b3e8157114c",
    "bpmn-js-bpmnlint": "^0.24.0",
    "bpmn-js-side-panel": "github:bpmn-os/bpmn-js-side-panel#6f4fcdb79bf0d99cf10052ff9a77083d39c2618b",
    "bpmnlint": "^10.3.0",
    "bpmnlint-utils": "^1.1.1",
    "diagram-js": "^15.18.0",
    "inherits": "^2.0.4",
    "min-dom": "^5.0.0",
    "tiny-svg": "^4.1.4"
  },
  "devDependencies": {
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-moddle": "^10.0.0",
    "less": "^4.6.7",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
